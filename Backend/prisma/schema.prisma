generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("alertavital_PRISMA_DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model alertas {
  id                   String                 @id @default(uuid()) @db.Uuid // ✅ Corrected
  usuario_id           String                 @db.Uuid
  tipo                 String
  descripcion          String?
  creada_en            DateTime               @default(now()) @db.Timestamptz(6)
  atendida             Boolean                @default(false)
  countdown_seg        Int?                   @default(30)
  estado               String?                @default("ABIERTA")
  latitud              Float?
  longitud             Float?
  precision_metros     Float?
  usuarios             usuarios               @relation(fields: [usuario_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  alertas_asignaciones alertas_asignaciones[]
  alertas_eventos      alertas_eventos[]
  alertas_posiciones   alertas_posiciones[]

  @@index([creada_en])
  @@index([estado])
  @@index([latitud, longitud])
  @@index([tipo])
  @@index([usuario_id])
}

model alertas_asignaciones {
  id            String            @id @default(uuid()) @db.Uuid // ✅ Corrected
  alerta_id     String            @db.Uuid
  cuidador_id   String            @db.Uuid
  orden         Int               @default(1)
  estado        asignacion_estado @default(PENDIENTE)
  notificada_en DateTime?         @db.Timestamptz(6)
  respondida_en DateTime?         @db.Timestamptz(6)
  distancia_m   Decimal?          @db.Decimal(12, 3)
  ml_score      Decimal?          @db.Decimal(10, 6)
  ml_model      String?
  ml_version    String?
  eta_seg       Int?
  alertas       alertas           @relation(fields: [alerta_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  usuarios      usuarios          @relation(fields: [cuidador_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([alerta_id, cuidador_id, orden])
  @@unique([alerta_id, estado])
  @@index([alerta_id, orden])
  @@index([cuidador_id])
  @@index([estado])
}

model alertas_eventos {
  id        String   @id @default(uuid()) @db.Uuid // ✅ Corrected
  alerta_id String   @db.Uuid
  evento    String
  metadata  Json?
  creado_en DateTime @default(now()) @db.Timestamptz(6)
  alertas   alertas  @relation(fields: [alerta_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([alerta_id, creado_en])
  @@index([evento])
}

model alertas_posiciones {
  id               String   @id @default(uuid()) @db.Uuid // ✅ Corrected
  alerta_id        String   @db.Uuid
  usuario_id       String   @db.Uuid
  rol              String
  latitud          Float
  longitud         Float
  precision_metros Float?
  capturada_en     DateTime @default(now()) @db.Timestamptz(6)
  alertas          alertas  @relation(fields: [alerta_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  usuarios         usuarios @relation(fields: [usuario_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([alerta_id, capturada_en])
  @@index([rol])
  @@index([usuario_id, capturada_en])
}

model cuidadores {
  id                                        String   @id @default(uuid()) @db.Uuid // ✅ Corrected
  adulto_id                                 String   @db.Uuid
  cuidador_id                               String   @db.Uuid
  creado_en                                 DateTime @default(now()) @db.Timestamptz(6)
  usuarios_cuidadores_adulto_idTousuarios   usuarios @relation("cuidadores_adulto_idTousuarios", fields: [adulto_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  usuarios_cuidadores_cuidador_idTousuarios usuarios @relation("cuidadores_cuidador_idTousuarios", fields: [cuidador_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([adulto_id, cuidador_id])
  @@index([adulto_id])
  @@index([cuidador_id])
}

model historial_medico {
  id             String   @id @default(uuid()) @db.Uuid // ✅ Corrected
  usuario_id     String   @db.Uuid
  condicion      String
  descripcion    String?
  medicamentos   String?
  alergias       String?
  fecha_registro DateTime @default(now()) @db.Date
  usuarios       usuarios @relation(fields: [usuario_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([usuario_id, fecha_registro])
}

model ubicaciones {
  id               String   @id @default(uuid()) @db.Uuid // ✅ Corrected
  usuario_id       String   @db.Uuid
  latitud          Float
  longitud         Float
  precision_metros Float?
  detectado_en     DateTime @default(now()) @db.Timestamptz(6)
  usuarios         usuarios @relation(fields: [usuario_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([usuario_id, detectado_en])
}

model usuarios {
  id                                          String                 @id @default(uuid()) @db.Uuid // ✅ Corrected
  rol                                         user_role
  nombre_completo                             String
  correo                                      String?                @unique @db.Citext
  telefono                                    String?
  contrasena_hash                             String
  correo_verificado_en                        DateTime?              @db.Timestamptz(6)
  creado_en                                   DateTime               @default(now()) @db.Timestamptz(6)
  ultimo_login                                DateTime?              @db.Timestamptz(6)
  fcm_token                                   String?
  alertas                                     alertas[]
  alertas_asignaciones                        alertas_asignaciones[]
  alertas_posiciones                          alertas_posiciones[]
  cuidadores_cuidadores_adulto_idTousuarios   cuidadores[]           @relation("cuidadores_adulto_idTousuarios")
  cuidadores_cuidadores_cuidador_idTousuarios cuidadores[]           @relation("cuidadores_cuidador_idTousuarios")
  historial_medico                            historial_medico[]
  ubicaciones                                 ubicaciones[]
  zonas_seguras                               zonas_seguras[]
}

model zonas_seguras {
  id           String   @id @default(uuid()) @db.Uuid // ✅ Corrected
  usuario_id   String   @db.Uuid
  nombre       String
  latitud      Float
  longitud     Float
  radio_metros Float
  creado_en    DateTime @default(now()) @db.Timestamptz(6)
  usuarios     usuarios @relation(fields: [usuario_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([usuario_id])
}

// Estos modelos son de Knex y ya no son necesarios si solo usas Prisma
// model knex_migrations { ... }
// model knex_migrations_lock { ... }

enum asignacion_estado {
  PENDIENTE
  NOTIFICADA
  EN_CAMINO
  RECHAZADA
  EXPIRADA
  COMPLETADA
}

enum user_role {
  ADULTO_MAYOR
  CUIDADOR
  ADMIN
}